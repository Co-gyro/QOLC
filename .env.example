# QOLC 環境変数テンプレート
# 実際の値は .env.local にコピーして記入する（.env.local は git 管理外）

# ============================================================
# Supabase
# ============================================================
# Supabase プロジェクト URL（例: https://abcdefg.supabase.co）
NEXT_PUBLIC_SUPABASE_URL=
# Anon key（クライアント側で使用、RLSで保護される前提）
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service Role key（サーバー側のみ、絶対にクライアントへ送らない）
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# USEN PSP（決済プロバイダ）
# ============================================================
# サイトコード / モールコード（テスト: TSJL / TSJM、本番: S203 / A300〜A3ZZ）
USEN_SITE_CD=TSJL
USEN_MALL_CD=TSJM
# HMACキーファイル（64バイトバイナリ）への絶対パス。コードにハードコードしない。
#   サイトのキー: 会員登録系API（entrybyjutyucd, get, inactivate, activate, delete）で使用
#   モールのキー: 与信/売上/取消系API（authbymemberid, salesadd, void 等）で使用
#   テスト: TSJL.NMK（サイト）/ TSJM.NMK（モール）、本番: S203.NMK
USEN_SITE_HMAC_KEY_PATH=/path/to/TSJL.NMK
USEN_MALL_HMAC_KEY_PATH=/path/to/TSJM.NMK
# 会員ID決済API ベースURL（HMAC-MD5, XMLレスポンス）
#   本番: https://inet-uketsuke1.netmove.jp/payment / テスト: https://inet-uketsuke.netmove.jp/payment
USEN_MEMBER_API_BASE_URL=https://inet-uketsuke.netmove.jp/payment
# 3DセキュアEC決済API ベースURL（HMAC-SHA256, 決済画面表示→ret_urlコールバック）
#   本番: https://inet-uketsuke1.netmove.jp/ec-payment-front / テスト: https://inet-uketsuke.netmove.jp/ec-payment-front
USEN_EC_API_BASE_URL=https://inet-uketsuke.netmove.jp/ec-payment-front

# ============================================================
# アプリ設定
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
