# QOLC 環境変数テンプレート
# 実際の値は .env.local にコピーして記入する（.env.local は git 管理外）

# ============================================================
# Supabase
# ============================================================
# Supabase プロジェクト URL（例: https://abcdefg.supabase.co）
NEXT_PUBLIC_SUPABASE_URL=
# Anon key（クライアント側で使用、RLSで保護される前提）
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service Role key（サーバー側のみ、絶対にクライアントへ送らない）
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# USEN PSP（決済プロバイダ）
# ============================================================
# 本番: S203 / テスト: TSJL（EC決済）, TSJM（会員ID決済）
USEN_SITE_CD=TSJL
USEN_MALL_CD=TSJM
# HMACキーファイル（バイナリ、64バイト）への絶対パス
# 本番: S203.NMK / テスト: TSJL.NMK, TSJM.NMK
USEN_HMAC_KEY_PATH=/path/to/TSJL.NMK
# API ベースURL
# 本番: https://inet-uketsuke1.netmove.jp
# テスト: https://inet-uketsuke.netmove.jp
USEN_API_BASE_URL=https://inet-uketsuke.netmove.jp
USEN_TOKEN_API_BASE_URL=https://inet-uketsuke.netmove.jp

# ============================================================
# アプリ設定
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
