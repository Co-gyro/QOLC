# QOLC 環境変数テンプレート
# 実際の値は .env.local にコピーして記入する（.env.local は git 管理外）

# ============================================================
# Supabase
# ============================================================
# Supabase プロジェクト URL（例: https://abcdefg.supabase.co）
NEXT_PUBLIC_SUPABASE_URL=
# Anon key（クライアント側で使用、RLSで保護される前提）
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service Role key（サーバー側のみ、絶対にクライアントへ送らない）
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# USEN PSP（決済プロバイダ）
# ============================================================
# サイトコード / モールコード（テスト: TSJL / TSJM、本番: S203 / A300〜A3ZZ）
USEN_SITE_CD=TSJL
USEN_MALL_CD=TSJM
# HMACキーファイル（64バイトバイナリ）への絶対パス。コードにハードコードしない。
#   サイトのキー: 会員登録系API（entrybyjutyucd, get, inactivate, activate, delete）で使用
#   モールのキー: 与信/売上/取消系API（authbymemberid, salesadd, void 等）で使用
#   テスト: TSJL.NMK（サイト）/ TSJM.NMK（モール）、本番: S203.NMK
USEN_SITE_HMAC_KEY_PATH=/path/to/TSJL.NMK
USEN_MALL_HMAC_KEY_PATH=/path/to/TSJM.NMK
# 会員ID決済API ベースURL（HMAC-MD5, XMLレスポンス）
#   テスト/本番とも inet-uketsuke1.netmove.jp を使用（区別は site_cd/mall_cd + HMACキー）。
USEN_MEMBER_API_BASE_URL=https://inet-uketsuke1.netmove.jp/payment
# トークン式EC決済API ベースURL（HMAC-SHA256, JSON）。カード登録/EC決済はこちら
USEN_TOKEN_EC_API_BASE_URL=https://inet-uketsuke1.netmove.jp/ec-payment-uhup
# group_id（USEN提供）。設定時は全APIに隠しパラメータとして付与され、サイト鍵で署名する
# （USEN推奨方式・配下複数モールに対応。テスト用と本番用で値が異なる）
USEN_GROUP_ID=
# トークン式チェックコードに使うHMACキー種別（site/mall）。USEN_GROUP_ID 設定時は強制 site
USEN_TOKEN_CHECK_KEY_TYPE=site
# USEN提供のフロントJSライブラリURL（ec-payment-web-adapter-token.umd.js）。USENから別途提供
# 開発用: https://vic29.netmove.co.jp/ec-payment/js/ec-payment-web-adapter-token-20260210.umd.js
# 本番用: https://payment-cdn.netmove.co.jp/ec-payment/static/js/ec-payment-web-adapter-token.umd.20260210.js
NEXT_PUBLIC_USEN_TOKEN_JS_URL=
# （任意）テスト時にSDKが使うUSENサーバURL。未指定なら本番扱い
NEXT_PUBLIC_USEN_TOKEN_EC_API_BASE_URL=

# ============================================================
# アプリ設定
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
